{
  "name": "hello-ar-web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "astro check",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "astro": "^7.0.3",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/three": "^0.185.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.75.0",
    "oxlint-tsgolint": "7.0.2001",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0"
}
