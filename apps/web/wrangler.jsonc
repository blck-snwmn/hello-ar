{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-06-29",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "hello-ar-web",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
}
